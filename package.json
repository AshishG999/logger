{
  "name": "@agstack/logger",
  "publishConfig": {
    "access": "public"
  },
  "version": "2.0.0",
  "description": "AGStack Runtime Kernel — lightweight, high-performance runtime lifecycle, HTTP interception, plugin execution, and observability foundation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./init": {
      "types": "./dist/init.d.ts",
      "import": "./dist/init.mjs",
      "require": "./dist/init.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "node benchmarks/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "agstack",
    "runtime",
    "kernel",
    "observability",
    "middleware",
    "nodejs",
    "plugin",
    "lifecycle"
  ],
  "author": "Ashish Gholap",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AshishG999/logger.git"
  },
  "homepage": "https://github.com/AshishG999/logger#readme",
  "bugs": {
    "url": "https://github.com/AshishG999/logger/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@agstack/plugin-sdk": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.0.0",
    "rimraf": "^5.0.10",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
